# RetroCause environment template
#
# Leave these empty to use explicit demo fallback paths where supported.
# Set one of the API keys below to enable real analysis.

# Preferred provider keys (set one)
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional model / timeout overrides
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60

# Optional source override for controlled live-mode degradation
# Example: RETROCAUSE_ENABLED_SOURCES=arxiv
RETROCAUSE_ENABLED_SOURCES=

# Optional trusted domains for web evidence ranking
# Example: RETROCAUSE_TRUSTED_DOMAINS=ntsb.gov,faa.gov,reuters.com
RETROCAUSE_TRUSTED_DOMAINS=

# Optional query/source budget controls
RETROCAUSE_HOT_QUERY_CACHE_SECONDS=90
RETROCAUSE_EVERGREEN_QUERY_CACHE_SECONDS=600
RETROCAUSE_SOURCE_MIN_INTERVAL_SECONDS=0.2

# Interactive live mode keeps expensive debate refinement off by default.
# Set to 1+ for offline/deeper analysis runs.
RETROCAUSE_DEBATE_MAX_ROUNDS=0
RETROCAUSE_COUNTERFACTUAL_MIN_SCORE=0.0
