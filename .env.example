# RetroCause environment template
#
# The OSS browser/API surface is keyless. Do not place provider secrets here.
#
# Hosted model/search credentials belong to the separate Pro implementation,
# where quotas, queues, audit logs, and encrypted credential storage can be
# designed intentionally.

# Optional timeout override for local development paths that still call networked
# sources.
OPENAI_TIMEOUT=60

# Optional frontend API base for local E2E or non-default backend ports.
NEXT_PUBLIC_RETROCAUSE_API_BASE=http://localhost:8000

# Optional source override for controlled source-path degradation
# Example: RETROCAUSE_ENABLED_SOURCES=arxiv
RETROCAUSE_ENABLED_SOURCES=

# Optional trusted domains for web evidence ranking
# Example: RETROCAUSE_TRUSTED_DOMAINS=ntsb.gov,faa.gov,reuters.com
RETROCAUSE_TRUSTED_DOMAINS=

# Optional query/source budget controls
RETROCAUSE_HOT_QUERY_CACHE_SECONDS=90
RETROCAUSE_EVERGREEN_QUERY_CACHE_SECONDS=600
RETROCAUSE_SOURCE_MIN_INTERVAL_SECONDS=0.2
RETROCAUSE_SOURCE_ERROR_COOLDOWN_SECONDS=30

# Local OSS keeps expensive debate refinement off by default.
# Set to 1+ only for offline/deeper development runs.
RETROCAUSE_DEBATE_MAX_ROUNDS=0
RETROCAUSE_COUNTERFACTUAL_MIN_SCORE=0.0
